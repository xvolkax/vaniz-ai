# =========================================================================
# Priya Voice Agent — Environment Configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =========================================================================

# ---------- App ----------
APP_ENV=production                 # development | production
LOG_LEVEL=INFO
SERVICE_REGION=blr1                # DigitalOcean region: blr1 (Bangalore) or sgp1 (Singapore)

# ---------- LiveKit ----------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---------- Deepgram (STT) ----------
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi            # multilingual Hindi-English code-mixed

# ---------- STT provider ----------
# sarvam = Saaras v3, India-hosted, Hindi-native (best Hindi/Hinglish quality).
# deepgram = Nova-3 multi (lower latency, weaker on Hindi/Hinglish).
STT_PROVIDER=sarvam
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=hi-IN          # or "unknown" for auto language-detect
SARVAM_STT_MODE=transcribe         # transcribe | translate | verbatim | translit | codemix

# ---------- OpenAI (LLM) ----------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ---------- Cartesia (TTS) ----------
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_MODEL=sonic-3
CARTESIA_VOICE_ID=your_hindi_voice_id
CARTESIA_LANGUAGE=hi               # project mode defaults to Hindi/Hinglish; use en for an English-first project

# ---------- Vobiz SIP Telephony ----------
VOBIZ_SIP_HOST=sip.vobiz.example        # Vobiz SIP proxy / registrar host
VOBIZ_SIP_PORT=5060
VOBIZ_SIP_USERNAME=your_sip_username
VOBIZ_SIP_PASSWORD=your_sip_password
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX        # Your Vobiz virtual number (E.164)
# Populated by scripts/setup_sip.py after trunk creation:
SIP_INBOUND_TRUNK_ID=
SIP_OUTBOUND_TRUNK_ID=
SIP_DISPATCH_RULE_ID=
AGENT_NAME=priya-agent

# ---------- Human warm transfer ----------
# Live sales consultant number Priya connects the caller to (uses the outbound
# trunk above). Blank => transfer disabled; Priya offers a callback instead.
HUMAN_AGENT_PHONE=+91XXXXXXXXXX
TRANSFER_TIMEOUT_SECONDS=20        # give up if the human doesn't answer
TRANSFER_HOLD_MUSIC=true           # play hold music to the caller while dialling

# ---------- PostgreSQL (async) ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=priya
POSTGRES_USER=priya
POSTGRES_PASSWORD=change_me_strong_password
# Full async DSN (overrides individual fields if set)
DATABASE_URL=postgresql+asyncpg://priya:change_me_strong_password@postgres:5432/priya

# ---------- API server ----------
API_HOST=0.0.0.0
API_PORT=8080
METRICS_PORT=9090

# ---------- JWT auth (SaaS dashboard control-plane) ----------
# Sign key for dashboard JWTs. MUST be a long random string in production
# (>= 32 bytes). Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720      # dashboard session length (12h)
ALLOW_PUBLIC_SIGNUP=true                 # allow POST /auth/register to create tenants

# ---------- Agent knowledge source (multi-tenant) ----------
# db  = properties served per-tenant from Postgres (SaaS; dashboard-managed).
# yaml = legacy single-tenant project.yaml (see AGENT_CONTEXT_MODE=project).
KNOWLEDGE_SOURCE=db
# Fallback tenant slug for inbound calls that can't be routed by dialed number
# (single-tenant / dev). Blank => no fallback.
DEFAULT_TENANT_SLUG=

# ---------- Turn detection / endpointing ----------
MIN_ENDPOINTING_DELAY=0.4          # seconds - fast but natural
MAX_ENDPOINTING_DELAY=6.0
ALLOW_INTERRUPTIONS=true
# BVC telephony noise cancellation (needs LiveKit Cloud entitlement; off by default)
NOISE_CANCELLATION_ENABLED=false

# ===================== Phase 2 (interfaces only) =========================
# ---------- CRM ----------
CRM_PROVIDER=noop                  # noop | zoho | hubspot | salesforce
CRM_API_KEY=
CRM_BASE_URL=

# ---------- WhatsApp follow-up ----------
WHATSAPP_PROVIDER=noop             # noop | cloud_api | gupshup | twilio
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# ---------- Google Calendar ----------
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google_sa.json

# ---------- Agent context mode ----------
# project = single builder / single project. Facts injected ONCE from
#           PROJECT_DATA_PATH; NO retrieval/RAG at runtime (lowest latency).
#           Priya speaks Hindi/Hinglish by default and adapts to the caller.
#           Use CARTESIA_LANGUAGE=hi.
# lite | full | ultra = generic multi-project modes (Hindi, markdown knowledge).
AGENT_CONTEXT_MODE=project
PROJECT_DATA_PATH=                  # blank = src/priya/project/project.yaml

# ---------- RAG / Vector DB ----------
# Only used by the generic (lite/full/ultra) modes. project mode ignores this.
RAG_PROVIDER=markdown              # markdown | qdrant | pgvector
QDRANT_URL=
QDRANT_API_KEY=
