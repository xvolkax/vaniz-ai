# =========================================================================
# Production .env for the DigitalOcean deploy (dashboard + API + agent).
# Copy this to the repo root as `.env` on the droplet and fill in real values:
#     cp deploy/env.production.template .env && nano .env
# Start from .env.example for the FULL list of tunables; the values below are
# the ones that MUST be correct for a production, IP-based full-stack deploy.
# =========================================================================

# ---- App ----
APP_ENV=production
LOG_LEVEL=INFO
SERVICE_REGION=blr1                 # blr1 (Bangalore) or sgp1 (Singapore)

# ---- Public edge / HTTPS (Caddy in the `web` service) ----
# Domain(s) served with automatic Let's Encrypt HTTPS. DNS A record(s) MUST
# point to the droplet IP first. Space-separate multiple hosts.
SITE_ADDRESS=vaniz.in www.vaniz.in
ACME_EMAIL=admin@vaniz.in

# ---- Database (compose service name is `postgres`) ----
POSTGRES_DB=priya
POSTGRES_USER=priya
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DATABASE_URL=postgresql+asyncpg://priya:CHANGE_ME_strong_db_password@postgres:5432/priya

# ---- SaaS control-plane auth (JWT) ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_long_random_at_least_32_bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
# Keep true to create the first tenant via the dashboard signup, then set to
# false and redeploy so no one else can self-register.
ALLOW_PUBLIC_SIGNUP=true

# ---- Agent knowledge source (multi-tenant, DB-backed) ----
KNOWLEDGE_SOURCE=db
# Optional fallback tenant slug for inbound calls not routed by dialed number.
DEFAULT_TENANT_SLUG=

# ---- Legacy bearer token (still required by config; unused by the dashboard) ----
API_AUTH_TOKEN=CHANGE_ME_api_token

# ---- LiveKit ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
AGENT_NAME=priya-agent

# ---- STT / LLM / TTS ----
STT_PROVIDER=sarvam
SARVAM_API_KEY=CHANGE_ME
DEEPGRAM_API_KEY=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
CARTESIA_API_KEY=CHANGE_ME
CARTESIA_MODEL=sonic-3
CARTESIA_VOICE_ID=CHANGE_ME
CARTESIA_LANGUAGE=hi

# ---- Vobiz SIP (fill trunk IDs after scripts/setup_sip.py) ----
VOBIZ_SIP_HOST=sip.vobiz.example
VOBIZ_SIP_USERNAME=CHANGE_ME
VOBIZ_SIP_PASSWORD=CHANGE_ME
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX
SIP_INBOUND_TRUNK_ID=
SIP_OUTBOUND_TRUNK_ID=
SIP_DISPATCH_RULE_ID=

# ---- Warm transfer (optional) ----
HUMAN_AGENT_PHONE=

# ---- Campaign engine ----
CAMPAIGN_MAX_CONCURRENCY=10
CAMPAIGN_RESUME_ON_STARTUP=true
